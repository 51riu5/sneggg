# ========================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit .env.local to git.
# ========================================================

# --- Supabase (database + auth) ---
# Get these from https://supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Shared PINs ---
# Set two PINs. Snegu uses one, Ribtu uses the other.
# Keep both 4-8 digits, no quotes.
SNEGU_PIN=1234
RIBTU_PIN=5678

# A random secret used to sign the session cookie.
# Generate any random 32+ char string (or run: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# --- Gemini (free AI) ---
# Get a key from https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, generous daily limit, no card needed.
GEMINI_API_KEY=AIzaSy...

# --- Optional: alternative AI providers if you ever switch ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=gemini

# --- Spotify playlist (already baked in, change if you want) ---
NEXT_PUBLIC_SPOTIFY_PLAYLIST=6LUsXD61YZWpwPZCzx9UWB

# --- Static Google Meet link (your personal room, used for study sessions) ---
# Get one: open meet.google.com -> "Create a new meeting" -> "For later" -> copy the link
# Format: https://meet.google.com/abc-defg-hij
NEXT_PUBLIC_MEET_LINK=https://meet.google.com/your-personal-room

# --- Web push (browser notifications, free) ---
# Generate VAPID keys ONCE with: npx web-push generate-vapid-keys
# Then paste both here. PUBLIC is exposed to client; PRIVATE stays server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:rishitmenon@gmail.com

# --- Your emails (used in scheduled-study notifications) ---
NEXT_PUBLIC_SNEGU_EMAIL=iamsnehask05@gmail.com
NEXT_PUBLIC_RIBTU_EMAIL=rishitmenon@gmail.com

# --- Vercel cron secret (auto-set by Vercel; only set manually for testing) ---
# Generate with: openssl rand -hex 32  (or any 32+ char random string)
CRON_SECRET=replace-with-random-secret-only-needed-for-cron
